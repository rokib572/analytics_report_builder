{
  "name": "analytics-report-builder",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "turbo lint && prettier --check . && turbo dev",
    "build": "turbo lint && prettier --check . && turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored --max-warnings 0",
      "prettier --check"
    ],
    "*.{json,md,yaml,yml,css,html}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.3",
    "prettier": "^3",
    "turbo": "latest",
    "typescript": "^5"
  }
}
